<Window x:Class="WarehouseManagement.ObjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseManagement"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:WarehouseManagement.UserControlG"
        ResizeMode="NoResize"
        WindowStyle="None"
        Title="Vật liệu"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <uc:ControlBarUC></uc:ControlBarUC>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <!--elements binding select-->
            <materialDesign:Card Grid.Row="0"
                                 Margin="5">
                <WrapPanel Margin="0 0 0 10">
                    <TextBox VerticalAlignment="Center"
                             Margin="5 5 15 5"
                             Text="{Binding SelectedItem.DisplayName, ElementName=LvObject}"
                             materialDesign:HintAssist.Hint="Tên vật tư"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <ComboBox x:Name="cbUnit"
                              materialDesign:HintAssist.Hint="Đơn vị đo"
                              Margin="5 5 15 5"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedItem.IdUnit, ElementName=LvObject, Mode=TwoWay}"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"></ComboBox>
                    <ComboBox x:Name="cbSuplier"
                              materialDesign:HintAssist.Hint="Nhà cung cấp"
                              Margin="5 5 15 5"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedItem.IdSuplier, ElementName=LvObject, Mode=TwoWay}"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"></ComboBox>
                    <TextBox VerticalAlignment="Center"
                             Margin="5 5 15 5"
                             Text="{Binding SelectedItem.Qrcode, ElementName=LvObject}"
                             materialDesign:HintAssist.Hint="QRCode"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <TextBox VerticalAlignment="Center"
                             Margin="5 5 15 5"
                             Text="{Binding SelectedItem.BarCode, ElementName=LvObject}"
                             materialDesign:HintAssist.Hint="BarCode"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    

                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1"
                                 Margin="5">
                <WrapPanel>
                    <Button Content="Thêm"
                            Command="{Binding AddCommand}"
                            Margin="5"
                            Width="100"></Button>
                    <Button Content="Sửa"
                            Command="{Binding EditCommand}"
                            Margin="5"
                            Width="100"></Button>
                    <Button Content="Xóa"
                            Command="{Binding DeleteCommand}"
                            Margin="5"
                            Width="100"></Button>
                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2"
                                 VerticalAlignment="Stretch"
                                 Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="LvObject"
                              SelectedItem="{Binding SelectedItem,Mode=OneWayToSource}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Id"
                                                DisplayMemberBinding="{Binding Id}"></GridViewColumn>
                                <GridViewColumn Header="Tên vật tư"
                                                DisplayMemberBinding="{Binding DisplayName}"></GridViewColumn>
                                <GridViewColumn Header="Đơn vị đo"
                                                DisplayMemberBinding="{Binding IdUnitNavigation.DisplayName}"></GridViewColumn>
                                <GridViewColumn Header="Nhà cung cấp"
                                                DisplayMemberBinding="{Binding IdSuplierNavigation.DisplayName}"></GridViewColumn>
                                <GridViewColumn Header="QRCode"
                                                DisplayMemberBinding="{Binding QRCode}"></GridViewColumn>
                                <GridViewColumn Header="BarCode"
                                                DisplayMemberBinding="{Binding BarCode}"></GridViewColumn>
                                
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
