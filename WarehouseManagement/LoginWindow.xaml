<Window x:Class="WarehouseManagement.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseManagement"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:WarehouseManagement.UserControlG"
        ResizeMode="NoResize"
        WindowStyle="None"
        mc:Ignorable="d"
        Title="LoginWindow" Height="506" Width="822"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <uc:ControlBarUC></uc:ControlBarUC>
        </Grid>

        <!-- ĐỔI CANVAS THÀNH GRID Ở ĐÂY -->
        <Grid Grid.Row="1">

            <!-- Dùng một StackPanel làm "hộp chứa", ép nó luôn nằm GIỮA Grid chính -->
            <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="300">
                <!-- Độ rộng của Form bằng đúng độ rộng TextBox của bạn -->

                <!-- Tiêu đề Đăng Nhập (Bỏ Canvas.Left/Top, dùng Margin bên dưới để tạo khoảng cách) -->
                <Label Content="Đăng Nhập" 
                   Height="44" 
                   FontFamily="Comic Sans MS" 
                   FontSize="24" 
                   HorizontalAlignment="Center" 
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

                <!-- Ô Username -->
                <TextBox x:Name="txtUsername" 
                     TextWrapping="Wrap" 
                     Height="40" 
                     materialDesign:HintAssist.Hint="Username" 
                     FontSize="18"
                     Margin="0,0,0,20"/>

                <!-- Ô Password -->
                <PasswordBox x:Name="txtPassword" 
                         Height="40" 
                         materialDesign:HintAssist.Hint="Password"  
                         FontSize="18"
                         Margin="0,0,0,30"/>

                <!-- Nút Đăng nhập (Căn giữa so với Form hoặc co giãn đầy Form tùy bạn) -->
                <Button x:Name="btnLogin" 
                    Content="Đăng nhập" 
                    HorizontalAlignment="Center"
                    Width="224" 
                    Height="40"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    materialDesign:ButtonAssist.CornerRadius="18" 
                    Background="Lime" 
                    FontWeight="Bold"
                    Margin="0,0,0,15"
                        Click="btnLogin_Click" />

                <!-- Nhãn hiển thị lỗi -->
                <Label x:Name="labelError" 
                   Content="Tên đăng nhập hoặc mật khẩu sai" 
                   HorizontalAlignment="Center"
                   Foreground="Red" 
                   Visibility="Hidden"/>

            </StackPanel>

        </Grid>
    </Grid>
</Window>
