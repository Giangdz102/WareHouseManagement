<Window x:Class="WarehouseManagement.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseManagement"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:WarehouseManagement.UserControlG"
        ResizeMode="NoResize"
        WindowStyle="None"
        mc:Ignorable="d"
        Title="LoginWindow" Height="506" Width="822"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <uc:ControlBarUC></uc:ControlBarUC>
        </Grid>
        <Canvas Grid.Row="1">
            <Label Content="Đăng Nhập" Canvas.Left="339" Canvas.Top="71" Height="44" Width="144" FontFamily="Comic Sans MS" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Top" FontWeight="Bold"/>
            <TextBox x:Name="txtUsername" Canvas.Left="261" TextWrapping="Wrap" Canvas.Top="149" Width="300" Height="40" materialDesign:HintAssist.Hint="Username" FontSize="18"/>
            <PasswordBox x:Name="txtPassword" Width="300" Height="40" materialDesign:HintAssist.Hint="Password"  HorizontalAlignment="Center" Canvas.Left="261" Canvas.Top="245" VerticalAlignment="Top" FontSize="18"/>
            <Button x:Name="btnLogin" Content="Đăng nhập" Canvas.Left="299" Canvas.Top="327" HorizontalAlignment="Left" VerticalAlignment="Top" Width="224"  Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Background="Lime" FontWeight="Bold" />
            <Label x:Name="labelError" Content="Tên đăng nhập hoặc mật khẩu sai" Canvas.Left="318" Canvas.Top="395" Foreground="Red" Visibility="Hidden"/>
        </Canvas>
    </Grid>
</Window>
