<UserControl x:Class="WarehouseManagement.UserControlG.ControlBarUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WarehouseManagement.UserControlG"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <materialDesign:ColorZone Mode="PrimaryLight">

            <DockPanel>

                <StackPanel DockPanel.Dock="Right"
                            Background="Transparent"
                            Orientation="Horizontal">

                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Margin" Value="2 4 2 4"></Setter>
                            <Setter Property="Width" Value="40"></Setter>
                        </Style>
                    </StackPanel.Resources>
                    
                    <Button ToolTip="Đóng"
                            ToolBar.OverflowMode="AsNeeded"
                            Background="#9A67EA" Click="Button_Click_2">
                        <materialDesign:PackIcon Kind="WindowMinimize" />
                    </Button>

                    <Button ToolTip="Đóng"
                            ToolBar.OverflowMode="AsNeeded"
                            Background="#9A67EA" Click="Button_Click_1">
                        <materialDesign:PackIcon Kind="WindowMaximize" />
                    </Button>

                    <Button ToolTip="Đóng"
                            ToolBar.OverflowMode="AsNeeded"
                            Background="OrangeRed" Click="Button_Click">
                        <materialDesign:PackIcon Kind="WindowClose" />
                    </Button>

                </StackPanel>

                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">

                    <ToggleButton Style="{DynamicResource MaterialDesignHamburgerToggleButton}" />

                   

                </StackPanel>

            </DockPanel>

        </materialDesign:ColorZone>
    </Grid>
</UserControl>
