<Window x:Class="WarehouseManagement.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseManagement"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:WarehouseManagement.UserControlG"
        ResizeMode="NoResize"
        WindowStyle="None"
        Title="Người dùng"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <uc:ControlBarUC></uc:ControlBarUC>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <!--elements binding select-->
            <materialDesign:Card Grid.Row="0"
                                 Margin="5">
                <WrapPanel Margin="0 0 0 10">
                    <TextBox VerticalAlignment="Center"
                             Margin="5 5 15 5"
                             Text="{Binding UserName , UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Tên đăng nhập"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <ComboBox materialDesign:HintAssist.Hint="Vai trò"
                              Margin="5 5 15 5"
                              ItemsSource="{Binding Role}"
                              SelectedItem="{Binding SelectedRole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"></ComboBox>
                   
                    <TextBox VerticalAlignment="Center"
                             Margin="5 5 15 5"
                             Text="{Binding DisplayName , UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Tên hiển thị"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    


                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1"
                                 Margin="5">
                <WrapPanel>
                    <Button Content="Thêm"
                            Command="{Binding AddCommand}"
                            Margin="5"
                            Width="100"></Button>
                    <Button Content="Sửa"
                            Command="{Binding EditCommand}"
                            Margin="5"
                            Width="100"></Button>
                    <Button Content="Xóa"
                            Command="{Binding DeleteCommand}"
                            Margin="5"
                            Width="100"></Button>
                    <Button Content="Đổi mật khẩu"
                            Command="{Binding ChangePasswordCommand}"
                            Margin="5"
                            Width="117"></Button>
                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2"
                                 VerticalAlignment="Stretch"
                                 Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListView ItemsSource="{Binding List}"
                              SelectedItem="{Binding SelectedItem,Mode=OneWayToSource}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Id"
                                                DisplayMemberBinding="{Binding Id}"></GridViewColumn>
                                <GridViewColumn Header="Tên đăng nhập"
                                                DisplayMemberBinding="{Binding UserName}"></GridViewColumn>
                                <GridViewColumn Header="Vai trò"
                                                DisplayMemberBinding="{Binding Role.DisplayName}"></GridViewColumn>
                                <GridViewColumn Header="Tên hiển thị"
                                                DisplayMemberBinding="{Binding DisplayName}"></GridViewColumn>
                               

                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
